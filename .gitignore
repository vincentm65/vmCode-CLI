# =============================================================================
# vmCode .gitignore
# =============================================================================
# Protects API keys and sensitive configuration from being committed

# Python
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
.venv/
venv/
ENV/
env/

# Node.js
node_modules/

# Deployment infrastructure (vmcode-proxy server)
#vmcode-proxy/

# Local model files
llama.cpp/
*.gguf

# Logs and conversations
conversations/
*.log

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Other notes/files
CLAUDE.md
GEMINI.md
AGENTS.md
nul
supabase/

.bone/
