  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vincentm65/bone-agent.git"
  },
  "bugs": {
    "url": "https://github.com/vincentm65/bone-agent/issues"
  },
  "homepage": "https://github.com/vincentm65/bone-agent",
  "engines": {
    "node": ">=14.0.0"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ]
