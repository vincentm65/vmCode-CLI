{
  "name": "bone-agent",
  "version": "1.3.2",
  "description": "A terminal-based AI coding assistant powered by OpenAI-style function calling",
  "main": "src/ui/main.py",
  "bin": {
    "bone": "bin/npm-wrapper.js"
  },
  "files": [
    "package.json",
    "LICENSE",
    "README.md",
    "requirements.txt",
    "config.yaml.example",
    "bin/npm-wrapper.js",
    "bin/rg",
    "bin/rg.exe",
    "src/**/*.py",
    "prompts"
  ],
  "scripts": {
    "postinstall": "echo 'bone-agent installed! Run with: bone'",
    "start": "node bin/npm-wrapper.js"
  },
  "keywords": [
    "ai",
